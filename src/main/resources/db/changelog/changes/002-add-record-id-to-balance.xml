<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd"
        objectQuotingStrategy="QUOTE_ALL_OBJECTS">

    <!--
      Links a balance row back to the record whose payment created it, so that
      editing a paid record's amount can find the ledger entry to correct.

      Nullable by design: balance rows created before this change, and manual
      adjustments made through POST /api/v1/balance, have no originating record.
      Those stay NULL and are reported as un-adjustable rather than guessed at.
    -->
    <changeSet id="002-add-record-id-to-balance" author="jointaccountmanager">

        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="balance" columnName="record_id"/>
            </not>
        </preConditions>

        <addColumn tableName="balance">
            <column name="record_id" type="BIGINT"/>
        </addColumn>

        <!--
          Unique rather than a plain index: a record is paid once and so may own at
          most one balance row. MySQL permits repeated NULLs, so the pre-existing
          unlinked rows are unaffected.
        -->
        <createIndex tableName="balance" indexName="ux_balance_record_id" unique="true">
            <column name="record_id"/>
        </createIndex>

    </changeSet>

</databaseChangeLog>
